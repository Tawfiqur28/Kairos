
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    match /technicalTerms/{termId} {
      // Allow any user to read technical terms (educational dictionary is public)
      allow read: if true;
      // Allow any signed-in user to write (for seeding/contribution)
      allow write: if isSignedIn();
    }

    // Subcollections under userProfiles
    match /userProfiles/{userId}/{allSubcollections=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
